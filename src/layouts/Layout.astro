---
import '../styles/global.css';
import siteData from '../data/site.json';

const {
  title = 'Public House — Cervecería en Laureles, Medellín',
  description = 'El pub de Laureles: cerveza artesanal e importada, fútbol en vivo, billar, dardos y las mejores alitas de la zona. Buen parche todos los días.',
  jsonLd = true, // solo la home; el 404 lo apaga con jsonLd={false}
} = Astro.props;

const site = 'https://public-house-demo.vercel.app';
const ogImage = `${site}/og.jpg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={site} />
    <meta name="theme-color" content="#141110" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / redes -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Public House" />
    <meta property="og:url" content={site} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Public House — cervecería en Laureles, Medellín" />
    <meta property="og:locale" content="es_CO" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: negocio local (SEO / GEO) -->
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BarOrPub',
      name: 'Public House',
      description,
      url: site,
      image: ogImage,
      telephone: `+${siteData.contacto.whatsapp}`,
      priceRange: '$$',
      servesCuisine: ['Cerveza artesanal', 'Alitas', 'Hamburguesas', 'Cócteles'],
      address: {
        '@type': 'PostalAddress',
        streetAddress: siteData.contacto.direccionL1,
        addressLocality: 'Medellín',
        addressRegion: 'Antioquia',
        addressCountry: 'CO',
      },
      openingHours: 'Tu-Su 16:00-02:00',
      aggregateRating: { '@type': 'AggregateRating', ratingValue: siteData.marca.rating, reviewCount: siteData.marca.reviewCount },
      sameAs: [siteData.contacto.instagram],
    })} />}

    <!-- Fuentes: Anton (titulares) · Rokkitt 900 (logo) · Mulish (cuerpo) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Rokkitt:wght@900&family=Mulish:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-negro text-crema antialiased">
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:bg-ambar focus:px-4 focus:py-2 focus:font-bold focus:text-negro2"
      >Saltar al contenido</a
    >
    <slot />

    <script>
      // revela .reveal al entrar en pantalla
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
