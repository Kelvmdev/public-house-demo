---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Página no encontrada — Public House"
  description="Esta página no existe. Vuelve al inicio para ver el menú, el fútbol en vivo y cómo llegar a Public House en Laureles."
  jsonLd={false}
  preloadHero={false}
>
  <Nav />
  <main id="contenido" tabindex="-1" class="flex min-h-svh flex-col items-center justify-center px-6 pt-28 text-center">
    <span class="inline-block origin-center scale-x-[.85] font-slab text-3xl font-black uppercase text-crema"
      >Public <span class="text-ambar">House</span></span
    >
    <p class="mt-8 font-display text-[clamp(3rem,12vw,6rem)] leading-none text-ambar">404</p>
    <h1 class="mt-2 font-display text-2xl font-normal uppercase">Esta página se fue de parche</h1>
    <p class="mt-3 max-w-md text-crema/80">No encontramos lo que buscabas, pero la cerveza sigue fría.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2.5 rounded-[.6rem] bg-ambar px-7 py-4 font-extrabold text-negro2 transition active:scale-95 hover:-translate-y-0.5 hover:bg-ambar2"
      ><span aria-hidden="true">🍺</span> Volver al inicio</a
    >
  </main>
  <Footer />
</Layout>
