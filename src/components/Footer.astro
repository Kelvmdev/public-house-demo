---
import site from '../data/site.json';
const wa = site.contacto.whatsappUrl;
const ig = site.contacto.instagram;
const links = site.nav;
const { direccionL1, direccionL2, horarioCorto, whatsappDisplay } = site.contacto;
const tagline = site.marca.tagline;
const maker = site.maker;
const year = 2026;
---
<footer class="border-t border-white/10 bg-negro2 py-14">
  <div class="mx-auto grid max-w-[1240px] gap-10 px-6 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <span class="inline-block origin-left scale-x-[.85] whitespace-nowrap font-slab text-2xl font-black uppercase leading-none text-crema"
        >Public <span class="text-ambar">House</span></span
      >
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-tenue">
        {tagline}
      </p>
      <div class="mt-5 flex gap-3">
        <a href={ig} target="_blank" rel="noopener" class="rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-crema/90 transition hover:border-ambar hover:text-ambar"><span aria-hidden="true">📸</span> Instagram</a>
        <a href={wa} class="rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-crema/90 transition hover:border-ambar hover:text-ambar"><span aria-hidden="true">💬</span> WhatsApp</a>
      </div>
    </div>

    <nav aria-label="Enlaces del pie">
      <h3 class="mb-4 font-display text-sm font-normal uppercase tracking-widest text-ambar">Menú</h3>
      <ul class="space-y-2 text-sm">
        {links.map((l) => (
          <li><a href={l.href} class="text-crema/80 transition hover:text-ambar">{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <h3 class="mb-4 font-display text-sm font-normal uppercase tracking-widest text-ambar">Contacto</h3>
      <address class="space-y-2 text-sm not-italic text-crema/80">
        <p>{direccionL1}<br />{direccionL2}</p>
        <p>Tel: <a href={wa} class="hover:text-ambar">{whatsappDisplay}</a></p>
        <p>{horarioCorto}</p>
      </address>
    </div>
  </div>

  <div class="mx-auto mt-10 flex max-w-[1240px] flex-col items-center justify-between gap-2 border-t border-white/10 px-6 pt-6 text-xs text-tenue sm:flex-row">
    <p>© {year} Public House · Laureles, Medellín</p>
    <p>Hecho con <span aria-hidden="true">🍺</span> por <a href={maker.url} target="_blank" rel="noopener" class="underline text-crema/70 hover:text-ambar">{maker.name}</a></p>
  </div>
</footer>
