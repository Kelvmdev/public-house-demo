---
// FAQ con <details> nativo (accesible, sin JS) + schema FAQPage para GEO/IA.
import site from '../data/site.json';
const head = site.faqHead;
const faq = site.faq;
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<section id="faq" class="bg-negro py-20 md:py-28">
  <div class="mx-auto max-w-[820px] px-6">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-5 flex items-center justify-center gap-3.5 text-[0.78rem] font-extrabold uppercase tracking-[.24em] text-ambar">
        <span class="h-0.5 w-12 bg-ambar"></span>{head.eyebrow}<span class="h-0.5 w-12 bg-ambar"></span>
      </p>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-normal uppercase leading-[1.02]" set:html={head.h2}></h2>
    </div>

    <div class="reveal mt-10 space-y-3">
      {faq.map((f) => (
        <details class="group rounded-xl border border-white/10 bg-negro2 px-5 open:border-ambar/40">
          <summary class="flex cursor-pointer items-center justify-between gap-4 py-4 font-display text-lg font-normal uppercase tracking-wide text-crema marker:content-none [&::-webkit-details-marker]:hidden">
            {f.q}
            <span aria-hidden="true" class="shrink-0 text-ambar transition-transform group-open:rotate-45">+</span>
          </summary>
          <p class="pb-5 leading-relaxed text-crema/80">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
