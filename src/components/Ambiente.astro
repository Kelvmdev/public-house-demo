---
// Galería tipo mosaico con fotos reales del pub
const fotos = [
  { src: '/img/g-bartender.webp', alt: 'Bartender sirviendo una cerveza en Public House', span: 'md:col-span-2 md:row-span-2' },
  { src: '/img/g-alitas.webp', alt: 'Alitas de la casa servidas en Public House', span: '' },
  { src: '/img/g-taps.webp', alt: 'Grifos de cerveza artesanal e importada', span: '' },
  { src: '/img/g-pour.webp', alt: 'Sirviendo una cerveza de barril bien fría', span: '' },
  { src: '/img/g-chat.webp', alt: 'El parche compartiendo en la barra del pub', span: '' },
];
---
<section id="ambiente" class="bg-negro2 py-20 md:py-28">
  <div class="mx-auto max-w-[1240px] px-6">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-5 flex items-center justify-center gap-3.5 text-[0.78rem] font-extrabold uppercase tracking-[.24em] text-ambar">
        <span class="h-0.5 w-[46px] bg-ambar"></span>El parche<span class="h-0.5 w-[46px] bg-ambar"></span>
      </p>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-normal uppercase leading-[1.02]">
        Así se vive <span class="text-ambar">Public House</span>
      </h2>
    </div>

    <div class="reveal mt-10 grid auto-rows-[180px] grid-cols-2 gap-3 md:grid-cols-4 md:auto-rows-[200px]">
      {fotos.map((f) => (
        <img
          src={f.src}
          alt={f.alt}
          loading="lazy"
          class:list={['h-full w-full rounded-xl object-cover transition duration-500 hover:brightness-110', f.span]}
        />
      ))}
    </div>
  </div>
</section>
