---
// Galería tipo mosaico con fotos reales del pub. Contenido en src/data/site.json.
import site from '../data/site.json';
const fotos = site.ambiente.galeria;
const a = site.ambiente;
---
<section id="ambiente" class="bg-negro2 py-20 md:py-28">
  <div class="mx-auto max-w-[1240px] px-6">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-5 flex items-center justify-center gap-3.5 text-[0.78rem] font-extrabold uppercase tracking-[.24em] text-ambar">
        <span class="h-0.5 w-12 bg-ambar"></span>{a.eyebrow}<span class="h-0.5 w-12 bg-ambar"></span>
      </p>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-normal uppercase leading-[1.02]" set:html={a.h2}></h2>
    </div>

    <div class="reveal mt-10 grid grid-cols-2 gap-3 md:grid-cols-4">
      {fotos.map((f) => (
        <img
          src={f.src}
          alt={f.alt}
          loading="lazy"
          class:list={[
            'w-full rounded-xl object-cover transition duration-500 hover:brightness-110',
            // tiles con proporción (escalan 320→4K, sin alturas fijas); el tile grande llena su celda 2×2 en md
            f.span ? ['aspect-[4/3] md:aspect-auto md:h-full', f.span] : 'aspect-[4/3]',
          ]}
        />
      ))}
    </div>
  </div>
</section>
