---
import site from '../data/site.json';
const wa = site.contacto.whatsappUrl;
const { direccionFull, horario, whatsappDisplay } = site.contacto;
const mapQuery = 'Public+House+Laureles+Transversal+40+Diagonal+74A+Medellin';
const mapEmbed = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
---
<section id="ubicacion" class="bg-negro py-20 md:py-28">
  <div class="mx-auto grid max-w-[1240px] gap-10 px-6 md:grid-cols-2 md:gap-14">
    <div class="reveal">
      <p class="mb-5 flex items-center gap-3.5 text-[0.78rem] font-extrabold uppercase tracking-[.24em] text-ambar">
        <span class="h-0.5 w-12 bg-ambar"></span>Dónde estamos
      </p>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-normal uppercase leading-[1.02]">
        Te esperamos en <span class="text-ambar">Laureles</span>
      </h2>

      <dl class="mt-8 space-y-5 text-crema/90">
        <div class="flex gap-4">
          <span class="text-xl" aria-hidden="true">📍</span>
          <div><dt class="font-bold text-crema">Dirección</dt><dd class="text-tenue">{direccionFull}</dd></div>
        </div>
        <div class="flex gap-4">
          <span class="text-xl" aria-hidden="true">🕒</span>
          <div><dt class="font-bold text-crema">Horario</dt><dd class="text-tenue">{horario}</dd></div>
        </div>
        <div class="flex gap-4">
          <span class="text-xl" aria-hidden="true">📞</span>
          <div><dt class="font-bold text-crema">Reservas</dt><dd class="text-tenue">{whatsappDisplay}</dd></div>
        </div>
      </dl>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href={wa} class="inline-flex items-center gap-2.5 rounded-[.6rem] bg-ambar px-6 py-3.5 font-extrabold text-negro2 transition active:scale-95 hover:-translate-y-0.5 hover:bg-ambar2"><span aria-hidden="true">🍺</span> Reservar por WhatsApp</a>
        <a href={mapLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 rounded-[.6rem] border-[1.5px] border-[#6b5a44] px-6 py-3.5 font-extrabold text-crema transition active:scale-95 hover:border-ambar hover:text-ambar"><span aria-hidden="true">🗺️</span> Cómo llegar</a>
      </div>
    </div>

    <!-- mapa con anti-hijack: overlay que se quita al hacer clic -->
    <div class="reveal group relative min-h-80 overflow-hidden rounded-2xl border border-white/10 shadow-2xl">
      <iframe
        title="Ubicación de Public House en Laureles, Medellín"
        src={mapEmbed}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="absolute inset-0 h-full w-full border-0"
      ></iframe>
      <button
        type="button"
        class="map-overlay absolute inset-0 flex items-center justify-center bg-negro2/40 text-sm font-bold text-crema backdrop-blur-[1px] transition hover:bg-negro2/20"
        aria-label="Activar el mapa"
      >
        <span class="rounded-full bg-negro2/80 px-4 py-2">Toca para interactuar con el mapa</span>
      </button>
    </div>
  </div>
</section>

<script>
  // anti-hijack: el mapa no captura el scroll hasta que el usuario hace clic
  document.querySelectorAll<HTMLButtonElement>('.map-overlay').forEach((ov) =>
    ov.addEventListener('click', () => {
      ov.style.display = 'none';
      ov.parentElement?.querySelector('iframe')?.focus();
    }),
  );
</script>
